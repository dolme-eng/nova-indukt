  "about": {
    "hero": {
      "title": "About NOVA INDUKT",
      "description": "Since 2018, we have been developing high-quality cookware for induction, combining German engineering with modern design. Our goal: the perfect cooking experience for every household."
    },
    "story": {
      "title": "Our Story",
      "paragraph1": "NOVA INDUKT was founded in 2018 in Berlin with a clear vision: to develop high-quality cookware specifically tailored to the requirements of modern induction cooktops. What started as a small startup has developed into one of the leading providers of premium kitchen accessories in Germany.",
      "paragraph2": "Our products are developed in collaboration with German engineers and designers and are subject to the strictest quality controls. We believe that good cookware must not only be functional but also sustainable.",
      "paragraph3": "Today we supply customers throughout Germany and the EU with our products and continuously work on innovative solutions for the kitchen of the future."
    },
