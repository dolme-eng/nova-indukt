# Site URL (required for SEO, sitemap, canonical URLs)
NEXT_PUBLIC_SITE_URL="https://nova-indukt.de"

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/nova_indukt"

# NextAuth
AUTH_SECRET="your-auth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Resend Email
RESEND_API_KEY="re_xxxxxxxx"
FROM_EMAIL="noreply@nova-indukt.de"
FROM_NAME="NOVA INDUKT"

# Cloudinary (for image uploads)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"

# Stripe (if using payments)
STRIPE_PUBLIC_KEY="pk_test_xxx"
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"

# SEO / Analytics
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION="google-verification-code"
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"

# Optional: Analytics/Monitoring
SENTRY_DSN=""
